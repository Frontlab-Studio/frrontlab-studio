
# 1. CONFIGURAÇÕES BÁSICAS E SEGURANÇA
# ------------------------------------------------------------------------------
# Desativar listagem de diretórios (Evita que pessoas vejam os arquivos da sua pasta)
Options -Indexes

# Esconder a assinatura do servidor
ServerSignature Off

# Cabeçalhos de Segurança (Prevenção de ataques XSS e Clickjacking)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    # HSTS - Força navegadores a usarem apenas conexão segura (1 ano de validade)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
</IfModule>

# ------------------------------------------------------------------------------
# 2. REDIRECIONAMENTOS E URLS LIMPAS (SEO EXTREMO)
# ------------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Forçar HTTPS em todas as requisições
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remover extensão .html das URLs (ex: /clinicas.html vira /clinicas)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.html -f
    RewriteRule ^(.*)$ $1.html [NC,L]

    # Remover barra invertida no final da URL para evitar penalização de conteúdo duplicado no Google
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [L,R=301]
</IfModule>

# ------------------------------------------------------------------------------
# 3. COMPRESSÃO DE ARQUIVOS (BROTLI E GZIP - BOOST DE LCP)
# ------------------------------------------------------------------------------
# Tenta usar Brotli (Algoritmo do Google, mais moderno e leve que GZIP)
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Fallback para GZIP caso o servidor não suporte Brotli
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ------------------------------------------------------------------------------
# 4. CACHE DE NAVEGADOR EXTREMO (LEVERAGE BROWSER CACHING)
# ------------------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    # CSS e JS (1 ano - Sempre que alterar o CSS, mude no HTML para style.css?v=2)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"

    # Mídia e Imagens Modernas (1 ano)
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType video/mp4 "access plus 1 year"

    # Fontes (1 ano)
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Gerenciamento avançado de Cache-Control para o PageSpeed não reclamar
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|webp|avif|jpg|jpeg|png|svg|woff2|mp4)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # O HTML nunca entra em cache prolongado para garantir que atualizações entrem no ar na hora
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

# Desativar ETags (Força a usar a regra de Cache-Control acima, exigência técnica para nota 100)
FileETag None